#!/bin/sh
# Mount virtual filesystems
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t tmpfs tmpfs /tmp
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true

# Create essential devices if devtmpfs failed
mknod /dev/null c 1 3 2>/dev/null || true
mknod /dev/zero c 1 5 2>/dev/null || true
mknod /dev/urandom c 1 9 2>/dev/null || true
mknod /dev/random c 1 8 2>/dev/null || true
mknod /dev/tty c 5 0 2>/dev/null || true

# Set hostname
hostname ijiege

# Configure network interface
ip link set eth0 up
ip addr add 10.0.2.15/24 dev eth0
ip route add default via 10.0.2.2

# Create nginx runtime dirs
mkdir -p /var/run /var/log/nginx /var/tmp /tmp
chown -R nginx:nginx /var/log/nginx /var/lib/nginx 2>/dev/null || true

# Start nginx
echo "Starting nginx..."
exec /usr/sbin/nginx -g "daemon off;"
